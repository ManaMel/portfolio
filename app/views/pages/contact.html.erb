<header class="bg-green-900 border-b border-amber-200/40 py-3 px-5 flex items-center shadow-lg">
  <div class="flex items-center gap-2">
    <span class="text-amber-200 text-2xl">♪</span>
    <h1 class="text-2xl font-bold text-amber-200 tracking-widest font-serif">Mysic</h1>
  </div>
</header>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Contact</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        お問い合わせ
      </h2>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
      <p class="text-sm text-stone-500 mb-6">
        Mysicに関するご質問・ご要望・不具合報告などは、以下のフォームよりお送りください。できる限り早急に対応させていただきます。
      </p>

      <%= form_with url: contact_path, method: :post, class: "space-y-5" do |f| %>

        <div>
          <%= label_tag :name, "お名前", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= text_field_tag :name, nil,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              placeholder: "山田 太郎",
              required: true %>
        </div>

        <div>
          <%= label_tag :email, "メールアドレス", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= email_field_tag :email, nil,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              placeholder: "example@example.com",
              required: true %>
          <p class="text-xs text-stone-400 mt-1.5">返信先のメールアドレスを入力してください</p>
        </div>

        <div>
          <%= label_tag :subject, "件名", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= select_tag :subject,
              options_for_select([
                "お問い合わせ内容を選択してください",
                "機能に関する質問",
                "不具合の報告",
                "要望・提案",
                "著作権に関する問い合わせ",
                "アカウントに関する問い合わせ",
                "その他"
              ]),
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-700 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              required: true %>
        </div>

        <div>
          <%= label_tag :message, "お問い合わせ内容", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= text_area_tag :message, nil,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              rows: 7,
              placeholder: "できるだけ詳しくご記入ください",
              required: true %>
        </div>

        <div class="bg-blue-50 border-l-2 border-blue-400 p-3 rounded-xl">
          <div class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div class="text-xs text-blue-800 space-y-0.5">
              <p>・ 返信には数日かかる場合があります</p>
              <p>・ 内容によっては返信できない場合があります</p>
            </div>
          </div>
        </div>

        <%= submit_tag "送信する",
            class: "w-full py-3 bg-green-900 hover:bg-green-800 text-amber-100 font-bold rounded-full text-sm shadow-sm tracking-wide transition duration-300 cursor-pointer" %>

      <% end %>
    </div>

    <div class="text-center">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        トップページに戻る
      <% end %>
    </div>

  </div>
</div>