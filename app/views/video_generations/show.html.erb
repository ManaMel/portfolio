<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-8">
    
    <!-- タイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">
        <%= @video_generation.title %>
      </h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>
    
    <!-- ステータス表示 -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        ステータス
      </h2>
      
      <div class="flex items-center gap-3">
        <span class="text-lg text-gray-700">現在の状態:</span>
        <span class="px-4 py-1.5 rounded-full text-sm font-semibold <%= 
          case @video_generation.status
          when 'created' then 'bg-blue-100 text-blue-800'
          when 'ready' then 'bg-green-100 text-green-800'
          when 'generating' then 'bg-amber-100 text-amber-800'
          when 'generated' then 'bg-green-100 text-green-800'
          when 'uploading' then 'bg-amber-100 text-amber-800'
          when 'uploaded' then 'bg-green-100 text-green-800'
          when 'failed' then 'bg-red-100 text-red-800'
          end
        %>">
          <%= case @video_generation.status
              when 'created' then '画像アップロード待ち'
              when 'ready' then '生成準備完了'
              when 'generating' then '動画生成中...'
              when 'generated' then '動画生成完了！'
              when 'uploading' then 'YouTubeアップロード中...'
              when 'uploaded' then 'YouTubeアップロード完了！'
              when 'failed' then "失敗: #{@video_generation.error_message}"
              end %>
        </span>
      </div>

      <% if @video_generation.generating? %>
        <div class="bg-blue-50 border-l-4 border-blue-800 text-blue-800 p-4 rounded mt-4">
          <div class="flex items-center gap-2">
            <span class="animate-spin inline-block w-5 h-5 border-2 border-blue-800 border-t-transparent rounded-full"></span>
            <span>ミキシング処理中です。完了までしばらくお待ちください...</span>
          </div>
        </div>
        <script>
          setTimeout(() => location.reload(), 5000);
        </script>
      <% elsif @video_generation.failed? %>
        <div class="bg-red-50 border-l-4 border-red-800 text-red-800 p-4 rounded mt-4">
          <p class="font-semibold">ミキシング処理に失敗しました</p>
          <% if @video_generation.error_message.present? %>
            <p class="text-sm mt-2"><%= @video_generation.error_message %></p>
          <% end %>
        </div>
      <% end %>
    </div>
    
    <!-- サムネイル画像アップロード -->
    <% unless @video_generation.generated? || @video_generation.uploaded? %>
      <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          サムネイル画像
        </h2>
        
        <% if @video_generation.thumbnail_image.attached? %>
          <div class="mb-6 text-center">
            <img src="<%= rails_blob_path(@video_generation.thumbnail_image) %>" 
                 alt="Thumbnail" 
                 class="max-w-md mx-auto rounded-lg shadow-lg">
          </div>
        <% end %>
        
        <%= form_with model: @video_generation, method: :patch do |f| %>
          <div class="mb-4">
            <%= f.label :thumbnail_image, "画像を選択（推奨: 16:9の横長画像）", class: "block text-sm font-semibold text-green-800 mb-2" %>
            <%= f.file_field :thumbnail_image, 
                            accept: "image/*", 
                            class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition" %>
            <p class="text-xs text-gray-500 mt-2">
              JPG, PNG形式対応。動画のサムネイルとして使用されます。
            </p>
          </div>
          
          <%= f.submit "画像をアップロード", 
              class: "w-full py-3 bg-amber-500 hover:bg-amber-600 text-green-900 font-bold rounded-lg shadow-md transition duration-300" %>
        <% end %>
      </div>
    <% end %>
    
    <!-- 動画生成ボタン -->
    <% if @video_generation.ready? %>
      <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          動画を生成
        </h2>
        <p class="text-gray-700 mb-6">
          サムネイル画像と音声から動画を生成します。
        </p>
        
        <%= button_to "動画を生成", 
                      generate_video_generation_path(@video_generation), 
                      method: :post, 
                      class: "w-full py-4 bg-green-800 hover:bg-green-700 text-amber-300 font-bold text-lg rounded-lg shadow-lg transition duration-300",
                      data: { confirm: "動画生成を開始しますか？" } %>
      </div>
    <% end %>
    
    <!-- 動画生成中 -->
    <% if @video_generation.generating? %>
      <div class="bg-white rounded-lg shadow-xl p-8 mb-6 border-4 border-amber-500">
        <div class="text-center">
          <div class="flex flex-col items-center gap-4">
            <span class="animate-spin inline-block w-16 h-16 border-4 border-amber-500 border-t-transparent rounded-full"></span>
            
            <div>
              <h3 class="text-2xl font-bold text-gray-800">動画を生成中です</h3>
              <p class="text-gray-600 mt-2">完了までしばらくお待ちください...</p>
              <p class="text-sm text-gray-500 mt-1">このページは自動的に更新されます</p>
            </div>
            
            <button onclick="location.reload()" 
                    class="px-6 py-2 border-2 border-amber-500 text-amber-600 hover:bg-amber-50 font-semibold rounded-lg transition duration-300">
              今すぐ更新
            </button>
          </div>
        </div>
      </div>
      
      <script>
        setTimeout(() => location.reload(), 5000);
      </script>
    <% end %>
    
    <!-- 生成された動画のプレビュー -->
    <% if @video_generation.generated? && @video_generation.generated_video.attached? %>
      <div class="bg-green-50 border-l-4 border-green-800 text-green-800 p-4 rounded mb-6">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="font-semibold">動画の生成が完了しました！</span>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          生成された動画
        </h2>
        
        <video controls class="w-full rounded-lg shadow-lg mb-4">
          <source src="<%= rails_blob_path(@video_generation.generated_video) %>" type="video/mp4">
        </video>
        
        <div class="text-right">
          <%= link_to "ダウンロード", 
                      rails_blob_path(@video_generation.generated_video, disposition: "attachment"), 
                      class: "inline-block px-6 py-2 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" %>
        </div>
      </div>
    <% end %>

    <!-- YouTubeアップロードセクション -->
    <% if @video_generation.generated? && !@video_generation.uploaded_to_youtube? %>
      
      <!-- 曲情報が未入力の場合 -->
      <% unless @video_generation.has_song_info? %>
        <div class="bg-amber-50 border-l-4 border-amber-600 p-6 rounded mb-6">
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-600 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <div class="flex-1">
              <h3 class="font-bold text-amber-800 mb-2">YouTubeアップロード前の確認</h3>
              <p class="text-amber-700 mb-4">著作権保護のため、YouTubeにアップロードする前に楽曲情報の入力が必要です。</p>
              <%= link_to edit_video_generation_path(@video_generation), 
                  class: "inline-block px-6 py-2 bg-amber-600 hover:bg-amber-700 text-white font-semibold rounded-lg shadow-md transition duration-300" do %>
                楽曲情報を入力する
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
      
      <!-- 曲情報が入力済みの場合 -->
      <% if @video_generation.has_song_info? %>
        <!-- YouTube説明文プレビュー -->
        <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
          <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
            YouTube説明文プレビュー
          </h2>
          
          <div class="bg-green-50 border-l-4 border-green-800 text-green-800 p-4 rounded mb-4">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>楽曲情報が入力されています</span>
            </div>
          </div>
          
          <div class="bg-gray-900 text-gray-100 p-4 rounded-lg font-mono text-sm overflow-x-auto">
            <pre><%= @video_generation.youtube_description %></pre>
          </div>
          
          <%= link_to "編集する", edit_video_generation_path(@video_generation), 
              class: "inline-block mt-4 px-4 py-2 border-2 border-green-800 text-green-800 hover:bg-green-50 font-semibold rounded-lg transition duration-300" %>
        </div>
        
        <!-- YouTubeアップロード -->
        <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
          <h2 class="text-xl font-serif font-semibold text-green-800 mb-6 pb-3 border-b-2 border-amber-400">
            YouTubeにアップロード
          </h2>
          
          <!-- 確認チェックリスト -->
          <div class="bg-gray-50 p-5 rounded-lg mb-6 border-l-4 border-amber-500">
            <h3 class="font-bold text-gray-800 mb-3">アップロード前の確認</h3>
            <div class="space-y-2">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-5 h-5 text-green-800 border-gray-300 rounded focus:ring-green-800" id="check-song-info" />
                <span class="text-gray-700">楽曲情報（曲名・アーティスト）を確認しました</span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-5 h-5 text-green-800 border-gray-300 rounded focus:ring-green-800" id="check-copyright" />
                <span class="text-gray-700">著作権表記が適切であることを確認しました</span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-5 h-5 text-green-800 border-gray-300 rounded focus:ring-green-800" id="check-content-id" />
                <span class="text-gray-700">YouTube Content IDによる権利処理を理解しました</span>
              </label>
            </div>
          </div>
          
          <!-- アップロード先選択 -->
          <div class="space-y-4 mb-6">
            <!-- Mysicコミュニティチャンネル -->
            <div class="border-2 border-green-800 rounded-lg p-4">
              <label class="flex items-start gap-4 cursor-pointer">
                <input type="radio" 
                       name="upload_destination" 
                       value="app_channel" 
                       class="mt-1 w-5 h-5 text-green-800"
                       id="app_channel"
                       checked>
                <div class="flex-1">
                  <span class="font-bold text-green-800 block mb-1">Mysicコミュニティチャンネル</span>
                  <p class="text-sm text-gray-600">
                    Mysic専用チャンネルに動画をアップロードします。<br>
                    他のユーザーと作品を共有できます。
                  </p>
                  <p class="text-xs text-amber-600 mt-2">
                    ※ 1日のアップロード上限があります（先着順）
                  </p>
                </div>
              </label>
            </div>
            
            <!-- 自分のYouTubeチャンネル -->
            <div class="border border-gray-200 rounded-lg p-4 <%= @can_upload_to_user_channel ? '' : 'opacity-60' %>">
              <label class="flex items-start gap-4 cursor-pointer">
                <input type="radio" 
                       name="upload_destination" 
                       value="user_channel" 
                       class="mt-1 w-5 h-5 text-green-800"
                       id="user_channel"
                       <%= 'disabled' unless @can_upload_to_user_channel %>>
                <div class="flex-1">
                  <span class="font-bold text-gray-800 block mb-1">自分のYouTubeチャンネル</span>
                  <p class="text-sm text-gray-600 mb-2">
                    あなた自身のチャンネルに動画をアップロードします。<br>
                    動画の所有権はあなたにあり、自由に編集・削除できます。
                  </p>
                  
                  <% unless @can_upload_to_user_channel %>
                    <%= link_to "YouTube認証", youtube_auth_path, 
                        class: "inline-block px-4 py-2 bg-green-800 hover:bg-green-700 text-amber-300 text-sm font-semibold rounded shadow-md transition" %>
                  <% end %>
                </div>
              </label>
            </div>
          </div>
          
          <%= form_with url: upload_to_youtube_video_generation_path(@video_generation), 
                        method: :post,
                        local: true,
                        id: "youtube-upload-form" do |f| %>
            <%= f.hidden_field :destination, value: 'app_channel', id: 'destination_field' %>
            
            <%= f.submit "YouTubeにアップロード", 
              class: "w-full py-4 bg-amber-500 hover:bg-amber-600 text-green-900 font-bold text-lg rounded-lg shadow-md transition duration-300",
              id: "youtube-upload-btn",
              disabled: true,
              data: { 
                confirm: "YouTubeにアップロードしますか？\n\n楽曲情報と著作権表記を確認してください。",
                disable_with: "アップロード中... しばらくお待ちください"
              } %>
          <% end %>
        </div>
        
        <script>
          const checkboxes = document.querySelectorAll('#check-song-info, #check-copyright, #check-content-id');
          const uploadBtn = document.getElementById('youtube-upload-btn');
          
          function updateButtonState() {
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            uploadBtn.disabled = !allChecked;
          }
          
          checkboxes.forEach(checkbox => {
            checkbox.addEventListener('change', updateButtonState);
          });
          
          document.querySelectorAll('input[name="upload_destination"]').forEach(radio => {
            radio.addEventListener('change', (e) => {
              document.getElementById('destination_field').value = e.target.value;
            });
          });
        </script>
      <% end %>
    <% end %>
    
    <!-- YouTubeアップロード中 -->
    <% if @video_generation.uploading? %>
      <div class="bg-white rounded-lg shadow-xl p-8 mb-6 border-4 border-amber-500">
        <div class="text-center">
          <div class="flex flex-col items-center gap-4">
            <span class="animate-spin inline-block w-16 h-16 border-4 border-amber-500 border-t-transparent rounded-full"></span>
            
            <div>
              <h3 class="text-2xl font-bold text-gray-800">YouTubeにアップロード中...</h3>
              <p class="text-gray-600 mt-2">完了までしばらくお待ちください</p>
              <p class="text-sm text-gray-500 mt-1">このページは自動的に更新されます</p>
            </div>
            
            <button onclick="location.reload()" 
                    class="px-6 py-2 border-2 border-amber-500 text-amber-600 hover:bg-amber-50 font-semibold rounded-lg transition duration-300">
              今すぐ更新
            </button>
          </div>
        </div>
      </div>
      
      <script>
        setTimeout(() => location.reload(), 5000);
      </script>
    <% end %>
    
    <!-- YouTubeアップロード完了 -->
    <% if @video_generation.uploaded? && @video_generation.youtube_video_id.present? %>
      <div class="bg-green-50 border-l-4 border-green-800 text-green-800 p-4 rounded mb-6">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="font-semibold">YouTubeへのアップロードが完了しました！</span>
        </div>
      </div>
      
      <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          YouTube動画
        </h2>
        
        <div class="aspect-video mb-4">
          <iframe 
            width="100%" 
            height="100%" 
            src="https://www.youtube.com/embed/<%= @video_generation.youtube_video_id %>" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
            allowfullscreen
            class="rounded-lg shadow-lg">
          </iframe>
        </div>
        
        <div class="text-right">
          <%= link_to @video_generation.youtube_url, 
                      target: "_blank", 
                      class: "inline-block px-6 py-2 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
            YouTubeで見る
          <% end %>
        </div>
      </div>
    <% end %>
    
    <!-- 削除ボタン -->
    <div class="flex gap-4 mb-6">
      <%= link_to "← 動画一覧に戻る", video_generations_path, 
          class: "px-6 py-2 text-gray-600 hover:text-gray-800 font-semibold hover:underline transition" %>
      
      <%= button_to "プロジェクトを削除", 
                    video_generation_path(@video_generation), 
                    method: :delete, 
                    class: "px-6 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-300",
                    data: { confirm: "本当に削除しますか？" } %>
    </div>
    
    <!-- ホームへ戻る -->
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
        ♪ ホームへ戻る
      <% end %>
    </div>
  </div>
</div>
