<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Video Creation</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        動画作成
      </h2>
    </div>

    <!-- 説明 -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-4 mb-5">
      <p class="text-sm text-stone-500">
        ミキシング済みの録音を選択して、動画を作成しましょう。
      </p>
    </div>

    <% if @recordings.empty? %>
      <!-- 録音がない場合 -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-14 mb-6 text-center">
        <p class="text-stone-600 text-sm font-semibold mb-1">ミキシング済みの録音がありません</p>
        <p class="text-stone-400 text-xs mb-6">先に録音をミキシングしてから、動画を作成できます。</p>
        <%= link_to recordings_path,
            class: "inline-block px-6 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 font-semibold rounded-full text-sm shadow-sm transition duration-300" do %>
          ♪ 録音ページへ
        <% end %>
      </div>

    <% else %>
      <!-- 録音リスト -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
        <div class="flex items-center justify-between mb-5 pb-3 border-b border-stone-100">
          <h2 class="text-sm font-semibold text-green-900 tracking-wide">録音を選択</h2>
          <span class="text-xs text-stone-400"><%= @recordings.count %>件</span>
        </div>

        <div class="space-y-3">
          <% @recordings.each do |recording| %>
            <div class="flex flex-col gap-3 p-4 rounded-xl border border-stone-100 hover:border-green-800/20 hover:bg-stone-50 transition duration-300">

              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <h3 class="text-sm font-semibold text-green-900 truncate">
                    <%= recording.title %>
                  </h3>
                  <p class="text-xs text-stone-400 mt-0.5">
                    <%= recording.created_at.strftime("%Y年%m月%d日") %>
                  </p>
                </div>

                <%= link_to new_video_generation_path(recording_id: recording.id),
                    class: "flex-shrink-0 px-4 py-1.5 bg-green-900 hover:bg-green-800 text-amber-100 text-xs font-semibold rounded-full shadow-sm transition duration-300" do %>
                  動画作成
                <% end %>
              </div>

              <% if recording.generated_audio.attached? %>
                <div>
                  <p class="text-xs text-stone-400 mb-1.5">プレビュー</p>
                  <audio controls class="w-full" style="height: 36px;">
                    <source src="<%= rails_blob_path(recording.generated_audio) %>" type="audio/mpeg">
                  </audio>
                </div>
              <% end %>

            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- ホームへ戻る -->
    <div class="text-center">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
    </div>

  </div>
</div>