<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-5xl mx-auto px-4 py-8">
    
    <!-- タイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">動画作成</h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>

    <!-- 説明 -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-8 border-t-4 border-green-800">
      <p class="text-gray-700">
        ミキシング済みの録音を選択して、動画を作成しましょう。
      </p>
    </div>
    
    <% if @recordings.empty? %>
      <!-- 録音がない場合 -->
      <div class="bg-white rounded-lg shadow-xl p-12 border-t-4 border-green-800 text-center">
        <div class="text-6xl mb-4">🎵</div>
        <p class="text-xl font-semibold text-gray-700 mb-2">ミキシング済みの録音がありません</p>
        <p class="text-gray-600 mb-6">先に録音をミキシングしてから、動画を作成できます。</p>
        <%= link_to recordings_path, 
            class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-bold rounded-lg shadow-lg transition duration-300" do %>
          ♪ 録音ページへ
        <% end %>
      </div>
      
    <% else %>
      <!-- 録音リスト -->
      <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-6 pb-3 border-b-2 border-amber-400">
          録音を選択
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @recordings.each do |recording| %>
            <div class="border border-gray-200 rounded-lg p-5 hover:border-green-800 hover:shadow-md transition duration-300">
              <h3 class="text-lg font-semibold text-green-800 mb-2">
                <%= recording.title %>
              </h3>
              
              <p class="text-sm text-gray-600 mb-4">
                作成日: <%= recording.created_at.strftime("%Y年%m月%d日") %>
              </p>
              
              <% if recording.generated_audio.attached? %>
                <div class="mb-4">
                  <p class="text-xs text-gray-500 mb-2">プレビュー:</p>
                  <audio controls class="w-full" style="height: 40px;">
                    <source src="<%= rails_blob_path(recording.generated_audio) %>" type="audio/mpeg">
                  </audio>
                </div>
              <% end %>
              
              <div class="text-center mt-4">
                <%= link_to new_video_generation_path(recording_id: recording.id), 
                    class: "inline-block w-full px-4 py-2 bg-amber-500 hover:bg-amber-600 text-green-900 font-semibold rounded-lg shadow-md transition duration-300" do %>
                  この録音で動画作成
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    
    <!-- ホームへ戻る -->
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
        ♪ ホームへ戻る
      <% end %>
    </div>
  </div>
</div>
