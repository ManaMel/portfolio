<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Song Info</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        楽曲情報の入力
      </h2>
    </div>

    <!-- 注意喚起 -->
    <div class="bg-amber-50 border-l-2 border-amber-400 p-4 rounded-xl mb-6">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div>
          <h3 class="text-xs font-bold text-amber-800 mb-1">著作権保護のため楽曲情報が必要です</h3>
          <p class="text-xs text-amber-700">正確な情報を入力してください。YouTube Content IDにより自動的に権利者に収益が分配されます。</p>
        </div>
      </div>
    </div>

    <%= form_with model: @video_generation, class: "space-y-4" do |f| %>

      <!-- 動画情報 -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6">
        <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
          動画情報
        </h2>

        <div class="space-y-4">
          <div>
            <%= f.label :title, "動画タイトル", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
            <%= f.text_field :title,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                placeholder: "例: Let It Go カバー" %>
          </div>

          <div>
            <%= f.label :body, "動画の説明文（任意）", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
            <%= f.text_area :body,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                rows: 3,
                placeholder: "動画についての説明や感想など" %>
            <p class="text-xs text-stone-400 mt-1.5">楽曲情報は自動的に追加されます</p>
          </div>
        </div>
      </div>

      <!-- 楽曲情報 -->
      <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6">
        <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
          楽曲情報 <span class="text-red-500 ml-1">必須</span>
        </h2>

        <div class="space-y-4">
          <div>
            <%= f.label :song_title, class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" do %>
              曲名 <span class="text-red-500">*</span>
            <% end %>
            <%= f.text_field :song_title,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                placeholder: "例: Let It Go",
                required: true %>
          </div>

          <div>
            <%= f.label :original_artist, class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" do %>
              原曲アーティスト <span class="text-red-500">*</span>
            <% end %>
            <%= f.text_field :original_artist,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                placeholder: "例: Idina Menzel",
                required: true %>
          </div>

          <div>
            <%= f.label :composer, "作曲者（わかれば）", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
            <%= f.text_field :composer,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                placeholder: "例: Kristen Anderson-Lopez, Robert Lopez" %>
          </div>

          <div>
            <%= f.label :lyricist, "作詞者（わかれば）", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
            <%= f.text_field :lyricist,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                placeholder: "例: Kristen Anderson-Lopez, Robert Lopez" %>
          </div>

          <div>
            <%= f.label :copyright_notes, "権利情報・備考", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
            <%= f.text_area :copyright_notes,
                class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
                rows: 3,
                placeholder: "例: ©Disney / JASRACコード: 123-4567-8" %>
            <p class="text-xs text-stone-400 mt-1.5">JASRACコード、出版社、権利者情報など（任意）</p>
          </div>
        </div>
      </div>

      <!-- 著作権注意事項 -->
      <div class="bg-stone-100 rounded-2xl border border-stone-200 px-6 py-5">
        <h3 class="text-xs font-bold text-stone-600 mb-3">著作権に関する注意</h3>
        <ul class="space-y-1.5 text-xs text-stone-500 list-disc list-inside">
          <li>カバー楽曲をYouTubeにアップロードする場合、楽曲情報の明記が推奨されます</li>
          <li>YouTube Content IDにより自動的に権利者に収益が分配されます</li>
          <li>楽曲によっては地域制限がかかる場合があります</li>
          <li>
            不明な場合は、
            <a href="https://www.jasrac.or.jp/" target="_blank" class="text-green-700 hover:underline">JASRAC</a>
            や
            <a href="https://support.google.com/youtube/answer/2797370" target="_blank" class="text-green-700 hover:underline">YouTubeのガイドライン</a>
            を確認してください
          </li>
        </ul>
      </div>

      <!-- 送信ボタン -->
      <div class="flex items-center justify-between pt-1">
        <%= link_to "キャンセル", @video_generation,
            class: "text-sm text-stone-400 hover:text-stone-600 underline underline-offset-2 transition" %>
        <%= f.submit "保存してアップロード画面へ",
            class: "px-8 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 text-sm font-bold rounded-full shadow-sm tracking-wide transition duration-300 cursor-pointer" %>
      </div>

    <% end %>

    <!-- ホームへ戻る -->
    <div class="text-center mt-6">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
    </div>

  </div>
</div>