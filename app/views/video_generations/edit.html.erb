<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-2xl mx-auto px-4 py-8">
    
    <!-- タイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">楽曲情報の入力</h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>
    
    <!-- 注意喚起 -->
    <div class="bg-amber-50 border-l-4 border-amber-600 p-5 rounded mb-6">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-600 flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div>
          <h3 class="font-bold text-amber-800 mb-1">著作権保護のため楽曲情報が必要です</h3>
          <p class="text-sm text-amber-700">正確な情報を入力してください。YouTube Content IDにより自動的に権利者に収益が分配されます。</p>
        </div>
      </div>
    </div>
    
    <%= form_with model: @video_generation, class: "space-y-6" do |f| %>
      <!-- 動画情報セクション -->
      <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          動画情報
        </h2>
        
        <!-- タイトル -->
        <div class="mb-4">
          <%= f.label :title, "動画タイトル", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_field :title, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              placeholder: "例: Let It Go カバー" %>
        </div>
        
        <!-- 説明文 -->
        <div>
          <%= f.label :body, "動画の説明文（任意）", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_area :body, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              rows: 3, 
              placeholder: "動画についての説明や感想など" %>
          <p class="text-xs text-gray-500 mt-2">楽曲情報は自動的に追加されます</p>
        </div>
      </div>
      
      <!-- 楽曲情報セクション -->
      <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-amber-600">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          楽曲情報（必須）
        </h2>
        
        <!-- 曲名 -->
        <div class="mb-4">
          <%= f.label :song_title, class: "block text-sm font-semibold text-green-800 mb-2" do %>
            曲名 <span class="text-red-600">*</span>
          <% end %>
          <%= f.text_field :song_title, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              placeholder: "例: Let It Go", 
              required: true %>
        </div>
        
        <!-- 原曲アーティスト -->
        <div class="mb-4">
          <%= f.label :original_artist, class: "block text-sm font-semibold text-green-800 mb-2" do %>
            原曲アーティスト <span class="text-red-600">*</span>
          <% end %>
          <%= f.text_field :original_artist, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              placeholder: "例: Idina Menzel", 
              required: true %>
        </div>
        
        <!-- 作曲者 -->
        <div class="mb-4">
          <%= f.label :composer, "作曲者（わかれば）", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_field :composer, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              placeholder: "例: Kristen Anderson-Lopez, Robert Lopez" %>
        </div>
        
        <!-- 作詞者 -->
        <div class="mb-4">
          <%= f.label :lyricist, "作詞者（わかれば）", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_field :lyricist, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              placeholder: "例: Kristen Anderson-Lopez, Robert Lopez" %>
        </div>
        
        <!-- 権利情報 -->
        <div>
          <%= f.label :copyright_notes, "権利情報・備考", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_area :copyright_notes, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
              rows: 3, 
              placeholder: "例: ©Disney / JASRACコード: 123-4567-8" %>
          <p class="text-xs text-gray-500 mt-2">JASRACコード、出版社、権利者情報など（任意）</p>
        </div>
      </div>
      
      <!-- 注意事項 -->
      <div class="bg-gray-50 rounded-lg p-5 border-l-4 border-gray-400">
        <h3 class="font-bold text-gray-800 mb-3">著作権に関する注意</h3>
        <ul class="list-disc list-inside text-sm text-gray-700 space-y-1">
          <li>カバー楽曲をYouTubeにアップロードする場合、楽曲情報の明記が推奨されます</li>
          <li>YouTube Content IDにより自動的に権利者に収益が分配されます</li>
          <li>楽曲によっては地域制限がかかる場合があります</li>
          <li>不明な場合は、<a href="https://www.jasrac.or.jp/" target="_blank" class="text-green-700 hover:underline">JASRAC</a>や<a href="https://support.google.com/youtube/answer/2797370" target="_blank" class="text-green-700 hover:underline">YouTubeのガイドライン</a>を確認してください</li>
        </ul>
      </div>
      
      <!-- 送信ボタン -->
      <div class="flex gap-4">
        <%= f.submit "保存してアップロード画面へ", 
            class: "flex-1 py-3 bg-amber-500 hover:bg-amber-600 text-green-900 font-bold rounded-lg shadow-md transition duration-300" %>
        <%= link_to "キャンセル", @video_generation, 
            class: "px-6 py-3 text-gray-600 hover:text-gray-800 font-semibold hover:underline transition" %>
      </div>
    <% end %>
    
    <!-- ホームへ戻る -->
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
        ♪ ホームへ戻る
      <% end %>
    </div>
  </div>
</div>
