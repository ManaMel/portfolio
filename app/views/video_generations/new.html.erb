<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-2xl mx-auto px-4 py-8">
    
    <!-- タイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">動画プロジェクト作成</h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>
    
    <!-- 選択された録音 -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        選択された録音
      </h2>
      <p class="text-lg font-semibold text-gray-700 mb-4"><%= @recording.title %></p>
      
      <% if @recording.generated_audio.attached? %>
        <div class="bg-gray-50 p-4 rounded-lg border-l-4 border-green-800">
          <p class="text-sm font-semibold text-gray-700 mb-2">音声プレビュー</p>
          <audio controls class="w-full">
            <source src="<%= rails_blob_path(@recording.generated_audio) %>" type="audio/mpeg">
          </audio>
        </div>
      <% end %>
    </div>
    
    <!-- フォーム -->
    <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-6 pb-3 border-b-2 border-amber-400">
        プロジェクト設定
      </h2>
      
      <%= form_with model: @video_generation, class: "space-y-6" do |f| %>
        <%= f.hidden_field :recording_id, value: @recording.id %>
        
        <!-- タイトル -->
        <div>
          <%= f.label :title, "動画タイトル", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_field :title, 
                           class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
                           placeholder: "例: 私の歌ってみた動画",
                           required: true %>
        </div>
        
        <!-- 説明 -->
        <div>
          <%= f.label :body, "動画の説明（任意）", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.text_area :body, 
                          class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition", 
                          rows: 4, 
                          placeholder: "この動画について説明を書いてください..." %>
          <p class="text-xs text-gray-500 mt-2">
            YouTubeにアップロードする際、この説明が動画の概要欄に表示されます
          </p>
        </div>
        
        <!-- ボタン -->
        <div class="flex gap-4">
          <%= f.submit "プロジェクト作成", 
              class: "flex-1 py-3 bg-amber-500 hover:bg-amber-600 text-green-900 font-bold rounded-lg shadow-md transition duration-300" %>
          <%= link_to "キャンセル", video_generations_path, 
              class: "px-6 py-3 text-gray-600 hover:text-gray-800 font-semibold hover:underline transition" %>
        </div>
      <% end %>
    </div>
    
    <!-- ホームへ戻る -->
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
        ♪ ホームへ戻る
      <% end %>
    </div>
  </div>
</div>