<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Create Video</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        動画を作成する
      </h2>
    </div>

    <!-- 選択された録音 -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-4">
      <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-4 pb-3 border-b border-stone-100">
        選択された録音
      </h2>
      <p class="text-sm font-semibold text-green-900 mb-4"><%= @recording.title %></p>

      <% if @recording.generated_audio.attached? %>
        <div class="bg-stone-50 rounded-xl border border-stone-100 p-4">
          <p class="text-xs font-semibold text-stone-500 mb-2">音声プレビュー</p>
          <audio controls class="w-full" style="height: 36px;">
            <source src="<%= rails_blob_path(@recording.generated_audio) %>" type="audio/mpeg">
          </audio>
        </div>
      <% end %>
    </div>

    <!-- フォーム -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
      <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
        動画の設定
      </h2>

      <%= form_with model: @video_generation, class: "space-y-5" do |f| %>
        <%= f.hidden_field :recording_id, value: @recording.id %>

        <!-- タイトル -->
        <div>
          <%= f.label :title, "動画タイトル", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= f.text_field :title,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              placeholder: "例: 私の歌ってみた動画",
              required: true %>
        </div>

        <!-- 説明 -->
        <div>
          <%= f.label :body, "動画の説明（任意）", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= f.text_area :body,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              rows: 4,
              placeholder: "この動画について説明を書いてください..." %>
          <p class="text-xs text-stone-400 mt-1.5">
            YouTubeにアップロードする際、この説明が動画の概要欄に表示されます
          </p>
        </div>

        <!-- ボタン -->
        <div class="flex items-center justify-between pt-1">
          <%= link_to "キャンセル", video_generations_path,
              class: "text-sm text-stone-400 hover:text-stone-600 underline underline-offset-2 transition" %>
          <%= f.submit "動画を作成する",
              class: "px-8 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 text-sm font-bold rounded-full shadow-sm tracking-wide transition duration-300 cursor-pointer" %>
        </div>

      <% end %>
    </div>

    <!-- ホームへ戻る -->
    <div class="text-center">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
    </div>

  </div>
</div>