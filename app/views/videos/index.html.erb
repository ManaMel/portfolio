<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Search</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        曲を検索
      </h2>
    </div>

    <!-- 検索フォーム -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
      <div data-controller="youtube-autocomplete"
           data-youtube-autocomplete-url-value="<%= autocomplete_videos_path %>"
           class="relative">

        <%= form_with url: search_videos_path, method: :get, local: true do |f| %>
          <div class="flex gap-2">
            <%= f.text_field :keyword,
                data: {
                  youtube_autocomplete_target: "input",
                  action: "input->youtube-autocomplete#search"
                },
                placeholder: "曲名やアーティスト名を入力",
                autocomplete: "off",
                class: "flex-1 px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition" %>

            <%= f.submit "検索",
                class: "px-6 py-3 bg-green-900 hover:bg-green-800 text-amber-100 font-semibold rounded-full text-sm shadow-sm tracking-wide transition duration-300 cursor-pointer" %>
          </div>

          <!-- オートコンプリート結果 -->
          <ul data-youtube-autocomplete-target="results"
              class="autocomplete-results"></ul>
        <% end %>
      </div>
    </div>

    <!-- 検索結果 -->
    <% if @results.present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
        <div class="flex items-center justify-between mb-5 pb-3 border-b border-stone-100">
          <h2 class="text-sm font-semibold text-green-900 tracking-wide">検索結果</h2>
          <span class="text-xs text-stone-400"><%= @results.count %>件</span>
        </div>

        <div class="space-y-3">
          <% @results.each do |result| %>
            <div class="flex gap-4 p-3 rounded-xl border border-stone-100 hover:border-green-800/20 hover:bg-stone-50 transition duration-300">

              <!-- サムネイル -->
              <div class="w-32 h-20 flex-shrink-0 rounded-lg overflow-hidden bg-stone-100">
                <a href="<%= result[:youtube_url] %>" target="_blank" rel="noopener noreferrer">
                  <% video_id = find_youtube_id(result[:youtube_url]) %>
                  <% if video_id.present? %>
                    <img src="https://img.youtube.com/vi/<%= video_id %>/hqdefault.jpg"
                         alt="<%= result[:title] %>"
                         class="w-full h-full object-cover"
                         onerror="this.onerror=null; this.src='https://via.placeholder.com/192x108/e5e7eb/6b7280?text=No+Image'">
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-stone-300">
                      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
                      </svg>
                    </div>
                  <% end %>
                </a>
              </div>

              <!-- 動画情報 -->
              <div class="flex-1 flex flex-col justify-between min-w-0">
                <div>
                  <h3 class="text-sm font-semibold text-green-900 leading-snug line-clamp-2 mb-1">
                    <a href="<%= result[:youtube_url] %>"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="hover:text-green-700 transition">
                      <%= result[:title] %>
                    </a>
                  </h3>
                  <p class="text-xs text-stone-400 truncate"><%= result[:channel] %></p>
                </div>

                <%= form_with model: @video, url: videos_path, method: :post, local: true, data: { turbo: false }, class: "mt-2" do |f| %>
                  <%= f.hidden_field :video_url, value: result[:youtube_url] %>
                  <%= f.hidden_field :title, value: result[:title] %>
                  <%= f.hidden_field :channel, value: result[:channel] %>
                  <%= f.submit "この動画を選ぶ",
                      class: "px-4 py-1.5 bg-green-900 hover:bg-green-800 text-amber-100 text-xs font-semibold rounded-full shadow-sm transition duration-300 cursor-pointer" %>
                <% end %>
              </div>

            </div>
          <% end %>
        </div>
      </div>

    <% elsif params[:keyword].present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-14 mb-6 text-center">
        <p class="text-stone-500 text-sm mb-1">検索結果が見つかりませんでした</p>
        <p class="text-stone-400 text-xs">別のキーワードで検索してみてください</p>
      </div>
    <% end %>

    <!-- ホームへ戻る -->
    <div class="text-center">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
    </div>

  </div>
</div>