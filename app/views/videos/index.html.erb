<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-4xl mx-auto px-4 py-8">
    
    <!-- タイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">曲を検索</h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>

    <!-- 検索フォーム -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-8 border-t-4 border-green-800">
      <div data-controller="youtube-autocomplete" 
           data-youtube-autocomplete-url-value="<%= autocomplete_videos_path %>"
           class="relative">
        
        <%= form_with url: search_videos_path, method: :get, local: true do |f| %>
          <div class="flex gap-3">
            <%= f.text_field :keyword, 
                data: { 
                  youtube_autocomplete_target: "input",
                  action: "input->youtube-autocomplete#search"
                },
                placeholder: "曲名やアーティスト名を入力",
                autocomplete: "off",
                class: "flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition" %>
            
            <%= f.submit "検索", 
                class: "px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" %>
          </div>

          <!-- オートコンプリート結果 -->
          <ul data-youtube-autocomplete-target="results" 
              class="autocomplete-results"></ul>
        <% end %>
      </div>
    </div>

    <!-- 検索結果 -->
    <% if @results.present? %>
      <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-green-800">
        <h2 class="text-xl font-serif font-semibold text-green-800 mb-6 pb-3 border-b-2 border-amber-400">
          検索結果 (<%= @results.count %>件)
        </h2>
        
        <div class="space-y-4">
          <% @results.each do |result| %>
            <div class="border border-gray-200 rounded-lg overflow-hidden hover:border-green-800 hover:shadow-md transition duration-300">
              <div class="flex">
                <!-- サムネイル -->
                <div class="w-48 flex-shrink-0 bg-gray-100">
                  <a href="<%= result[:youtube_url] %>" 
                     target="_blank" 
                     rel="noopener noreferrer">
                    <% video_id = find_youtube_id(result[:youtube_url]) %>
                    <% if video_id.present? %>
                      <img src="https://img.youtube.com/vi/<%= video_id %>/hqdefault.jpg" 
                           alt="<%= result[:title] %>" 
                           class="w-full h-full object-cover"
                           onerror="this.onerror=null; this.src='https://via.placeholder.com/192x108/e5e7eb/6b7280?text=No+Image'">
                    <% else %>
                      <div class="w-full h-full flex items-center justify-center text-gray-400">
                        <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
                        </svg>
                      </div>
                    <% end %>
                  </a>
                </div>

                <!-- 動画情報 -->
                <div class="flex-1 p-4 flex flex-col justify-between">
                  <div>
                    <h3 class="font-semibold text-green-800 mb-1 line-clamp-2">
                      <a href="<%= result[:youtube_url] %>" 
                         target="_blank" 
                         rel="noopener noreferrer"
                         class="hover:text-green-600">
                        <%= result[:title] %>
                      </a>
                    </h3>
                    <p class="text-sm text-gray-600"><%= result[:channel] %></p>
                  </div>

                  <%= form_with model: @video, url: videos_path, method: :post, local: true, data: { turbo: false }, class: "mt-3" do |f| %>
                    <%= f.hidden_field :video_url, value: result[:youtube_url] %>
                    <%= f.hidden_field :title, value: result[:title] %>
                    <%= f.hidden_field :channel, value: result[:channel] %>
                    <%= f.submit "この動画を選ぶ", 
                        class: "px-5 py-2 bg-amber-500 hover:bg-amber-600 text-green-900 font-semibold rounded-lg shadow-md transition duration-300 cursor-pointer" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% elsif params[:keyword].present? %>
      <div class="text-center py-12">
        <div class="bg-white rounded-lg shadow-xl p-12">
          <div class="text-6xl mb-4"></div>
          <p class="text-xl text-gray-700 mb-2">検索結果が見つかりませんでした</p>
          <p class="text-gray-500">別のキーワードで検索してみてください</p>
        </div>
      </div>
    <% end %>

    <!-- ホームへ戻る -->
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
        ♪ ホームへ戻る
      <% end %>
    </div>
  </div>
</div>