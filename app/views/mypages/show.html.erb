<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-5xl mx-auto px-4 py-8">
    
    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">マイページ</h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>

    <!-- ナビゲーションボタン -->
    <div class="flex justify-end gap-3 mb-6">
      <%= link_to recordings_path, 
          class: "px-5 py-2 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" do %>
        ♪ 録音する
      <% end %>
    </div>

    <!-- Flash メッセージ -->
    <% if notice %>
      <div class="bg-green-100 border-l-4 border-green-800 text-green-800 p-4 rounded mb-6">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="bg-red-100 border-l-4 border-red-800 text-red-800 p-4 rounded mb-6">
        <%= alert %>
      </div>
    <% end %>

    <!-- 録音一覧セクション -->
    <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-green-800">
      <h2 class="text-2xl font-serif font-bold text-green-800 mb-6 pb-3 border-b-2 border-amber-400">
        あなたの録音一覧
      </h2>
      
      <% if @recordings && @recordings.any? %>
        <div class="space-y-4">
          <% @recordings.each do |recording| %>
            <div class="border border-gray-200 rounded-lg p-5 hover:border-green-800 hover:shadow-md transition duration-300">
              <!-- タイトル行 -->
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xl font-semibold text-green-800">
                  <%= recording.title %>
                </h3>
                <span class="px-3 py-1 rounded-full text-xs font-semibold <%= recording.accompaniment.attached? ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800' %>">
                  <%= recording.accompaniment.attached? ? '✓ 伴奏あり' : '⚠ 伴奏なし' %>
                </span>
              </div>

              <!-- 完成音源 -->
              <% if recording.generated_audio.attached? %>
                <div class="mb-4 p-4 bg-green-50 rounded-lg border-l-4 border-green-800">
                  <p class="font-semibold text-green-800 mb-2">完成したミックス音源</p>
                  <audio controls class="w-full mb-2">
                    <source src="<%= url_for(recording.generated_audio) %>" type="audio/mpeg">
                    お使いのブラウザは audio タグに対応していません。
                  </audio>
                  <p class="text-xs text-gray-600">
                    <%= recording.generated_audio.filename %> 
                    (<%= number_to_human_size(recording.generated_audio.byte_size) %>)
                  </p>
                </div>
              <% end %>

              <!-- 詳細情報 -->
              <div class="grid grid-cols-2 gap-3 text-sm text-gray-700 mb-4">
                <div class="flex items-center">
                  <span class="font-semibold mr-2">作成日時:</span>
                  <%= recording.created_at.strftime('%Y年%m月%d日 %H:%M') %>
                </div>
                <div class="flex items-center">
                  <span class="font-semibold mr-2">ステータス:</span>
                  <%= recording.status %>
                </div>
                <div class="flex items-center">
                  <span class="font-semibold mr-2">録音:</span>
                  <%= recording.original_audio.attached? ? '✓ あり' : '✗ なし' %>
                  <% if recording.original_audio.attached? %>
                    <span class="text-xs text-gray-500 ml-1">
                      (<%= number_to_human_size(recording.original_audio.byte_size) %>)
                    </span>
                  <% end %>
                </div>
                <div class="flex items-center">
                  <span class="font-semibold mr-2">伴奏:</span>
                  <%= recording.accompaniment.attached? ? '✓ あり' : '✗ なし' %>
                  <% if recording.accompaniment.attached? %>
                    <span class="text-xs text-gray-500 ml-1">
                      (<%= recording.accompaniment.filename %>)
                    </span>
                  <% end %>
                </div>
              </div>

              <!-- アクションボタン -->
              <div class="flex gap-2 justify-end">
                <% if recording.accompaniment.attached? %>
                  <%= link_to recording_path(recording), 
                      class: "px-4 py-2 bg-green-800 hover:bg-green-700 text-amber-300 text-sm font-semibold rounded shadow-md transition" do %>
                    タイミング調整
                  <% end %>
                <% else %>
                  <%= link_to select_accompaniment_recording_path(recording), 
                      class: "px-4 py-2 bg-amber-500 hover:bg-amber-600 text-green-900 text-sm font-semibold rounded shadow-md transition" do %>
                    伴奏をアップロード
                  <% end %>
                <% end %>
                
                <%= link_to recording_path(recording), 
                    data: { turbo_method: :delete, turbo_confirm: "「#{recording.title}」を削除しますか？" }, 
                    class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded shadow-md transition" do %>
                  削除
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-12">
          <div class="text-6xl mb-4">🎵</div>
          <p class="text-xl text-gray-600 mb-2">まだ録音がありません</p>
          <p class="text-gray-500 mb-6">最初の録音を作成してみましょう！</p>
          <%= link_to new_recording_path, 
              class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-bold rounded-lg shadow-lg transition duration-300" do %>
            ♪ 最初の録音を作成
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300 mr-4" do %>
        ♪ ホームへ戻る
      <% end %>
    </div>
</div>