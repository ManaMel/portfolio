<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">My Page</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        マイページ
      </h2>
    </div>

    <!-- ナビゲーション -->
    <div class="flex justify-end mb-5">
      <%= link_to recordings_path,
          class: "px-5 py-2 bg-green-900 hover:bg-green-800 text-amber-100 text-sm font-semibold rounded-full shadow-sm transition duration-300" do %>
        ♪ 録音する
      <% end %>
    </div>

    <!-- Flash メッセージ -->
    <% if notice %>
      <div class="bg-green-50 border-l-2 border-green-600 text-green-800 text-sm p-3 rounded-xl mb-5">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 border-l-2 border-red-500 text-red-800 text-sm p-3 rounded-xl mb-5">
        <%= alert %>
      </div>
    <% end %>

    <!-- 録音一覧 -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
      <div class="flex items-center justify-between mb-5 pb-3 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-green-900 tracking-wide">あなたの録音一覧</h2>
        <% if @recordings&.any? %>
          <span class="text-xs text-stone-400"><%= @recordings.count %>件</span>
        <% end %>
      </div>

      <% if @recordings && @recordings.any? %>
        <div class="space-y-4">
          <% @recordings.each do |recording| %>
            <div class="p-4 rounded-xl border border-stone-100 hover:border-green-800/20 hover:bg-stone-50 transition duration-300">

              <!-- タイトル行 -->
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-green-900 truncate mr-3">
                  <%= recording.title %>
                </h3>
                <span class="flex-shrink-0 px-2 py-0.5 rounded-full text-xs font-semibold <%= recording.accompaniment.attached? ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-700' %>">
                  <%= recording.accompaniment.attached? ? '✓ 伴奏あり' : '⚠ 伴奏なし' %>
                </span>
              </div>

              <!-- 完成音源 -->
              <% if recording.generated_audio.attached? %>
                <div class="mb-4 p-3 bg-stone-50 rounded-xl border border-stone-100">
                  <p class="text-xs font-semibold text-green-900 mb-2">完成したミックス音源</p>
                  <audio controls class="w-full mb-1.5" style="height: 36px;">
                    <source src="<%= url_for(recording.generated_audio) %>" type="audio/mpeg">
                  </audio>
                  <p class="text-xs text-stone-400">
                    <%= recording.generated_audio.filename %>
                    (<%= number_to_human_size(recording.generated_audio.byte_size) %>)
                  </p>
                </div>
              <% end %>

              <!-- 詳細情報 -->
              <div class="grid grid-cols-2 gap-2 text-xs text-stone-500 mb-4">
                <div>
                  <span class="font-semibold text-stone-600">作成日時: </span>
                  <%= recording.created_at.strftime('%Y年%m月%d日 %H:%M') %>
                </div>
                <div>
                  <span class="font-semibold text-stone-600">ステータス: </span>
                  <%= recording.status %>
                </div>
                <div>
                  <span class="font-semibold text-stone-600">録音: </span>
                  <%= recording.original_audio.attached? ? '✓ あり' : '✗ なし' %>
                  <% if recording.original_audio.attached? %>
                    (<%= number_to_human_size(recording.original_audio.byte_size) %>)
                  <% end %>
                </div>
                <div>
                  <span class="font-semibold text-stone-600">伴奏: </span>
                  <%= recording.accompaniment.attached? ? '✓ あり' : '✗ なし' %>
                  <% if recording.accompaniment.attached? %>
                    (<%= recording.accompaniment.filename %>)
                  <% end %>
                </div>
              </div>

              <!-- アクションボタン -->
              <div class="flex gap-2 justify-end">
                <% if recording.accompaniment.attached? %>
                  <%= link_to recording_path(recording),
                      class: "px-4 py-1.5 bg-green-900 hover:bg-green-800 text-amber-100 text-xs font-semibold rounded-full shadow-sm transition duration-300" do %>
                    タイミング調整
                  <% end %>
                <% else %>
                  <%= link_to select_accompaniment_recording_path(recording),
                      class: "px-4 py-1.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 text-xs font-semibold rounded-full transition duration-300" do %>
                    伴奏をアップロード
                  <% end %>
                <% end %>

                <%= link_to recording_path(recording),
                    data: { turbo_method: :delete, turbo_confirm: "「#{recording.title}」を削除しますか？" },
                    class: "px-4 py-1.5 bg-red-700/80 hover:bg-red-700 text-white text-xs font-semibold rounded-full shadow-sm transition duration-300" do %>
                  削除
                <% end %>
              </div>

            </div>
          <% end %>
        </div>

      <% else %>
        <div class="text-center py-12">
          <p class="text-stone-500 text-sm font-semibold mb-1">まだ録音がありません</p>
          <p class="text-stone-400 text-xs mb-6">最初の録音を作成してみましょう！</p>
          <%= link_to recordings_path,
              class: "inline-block px-6 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 font-semibold rounded-full text-sm shadow-sm transition duration-300" do %>
            ♪ 最初の録音を作成
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- ホームへ戻る -->
    <div class="text-center">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
    </div>

  </div>
</div>