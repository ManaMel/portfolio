<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Recording</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        歌声や演奏を録音
      </h2>
    </div>

    <!-- 録音コントロール -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-4">
      <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
        録音コントロール
      </h2>

      <div class="flex justify-center gap-3 mb-6">
        <button type="button" id="buttonStart"
                class="px-5 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 font-semibold rounded-full text-sm shadow-sm transition duration-300 disabled:bg-stone-300 disabled:text-stone-400">
          録音開始
        </button>
        <button type="button" id="buttonStop"
                class="px-5 py-2.5 bg-red-700/80 hover:bg-red-700 text-white font-semibold rounded-full text-sm shadow-sm transition duration-300 disabled:bg-stone-300 disabled:text-stone-400"
                disabled>
          録音停止
        </button>
        <button type="button" id="buttonPlay"
                class="px-5 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300 disabled:border-stone-200 disabled:text-stone-400">
          再生
        </button>
      </div>

      <!-- 波形表示 -->
      <div id="waveform" class="border border-stone-200 rounded-xl p-2 bg-stone-50"></div>
    </div>

    <!-- エフェクト設定 -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-4">
      <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
        エフェクト設定
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-semibold text-green-900 tracking-wide mb-2">音量</label>
          <input type="range" id="volumeSlider" min="0" max="10" step="0.01" value="1"
                 class="w-full h-1.5 bg-stone-200 rounded-full appearance-none cursor-pointer accent-green-800">
        </div>

        <div>
          <label class="block text-xs font-semibold text-green-900 tracking-wide mb-2">リバーブ</label>
          <input type="range" id="reverbSlider" min="0" max="1" step="0.01" value="0.5"
                 class="w-full h-1.5 bg-stone-200 rounded-full appearance-none cursor-pointer accent-green-800">
        </div>

        <div>
          <label class="block text-xs font-semibold text-green-900 tracking-wide mb-2">エコー遅延時間</label>
          <input type="range" id="echoDelay" min="0" max="1" step="0.01" value="0.3"
                 class="w-full h-1.5 bg-stone-200 rounded-full appearance-none cursor-pointer accent-green-800">
        </div>

        <div>
          <label class="block text-xs font-semibold text-green-900 tracking-wide mb-2">エコー残響量</label>
          <input type="range" id="echoFeedback" min="0" max="0.95" step="0.01" value="0.4"
                 class="w-full h-1.5 bg-stone-200 rounded-full appearance-none cursor-pointer accent-green-800">
        </div>
      </div>
    </div>

    <!-- 録音を保存 -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-4">
      <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
        録音を保存
      </h2>

      <div class="mb-4">
        <label class="block text-xs font-semibold text-green-900 tracking-wide mb-1.5">タイトル</label>
        <input id="recording_title" type="text"
               placeholder="例：サビだけ録音 2025/01/01"
               class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition">
      </div>

      <div class="mb-5 p-4 bg-stone-50 rounded-xl border border-stone-100">
        <p class="text-xs font-semibold text-stone-500 mb-1">録音データ</p>
        <div id="recording-info" class="text-sm text-stone-400">
          ※ まだ録音データが未取得です
        </div>
      </div>

      <button id="save-recording-btn"
              class="w-full py-3 bg-green-900 hover:bg-green-800 text-amber-100 font-bold rounded-full shadow-sm text-sm tracking-wide transition duration-300 disabled:bg-stone-300 disabled:text-stone-400"
              disabled>
        保存する
      </button>

      <div class="mt-4 text-center">
        <%= link_to mypage_path,
            class: "text-sm text-green-800 hover:text-green-600 underline underline-offset-2 transition" do %>
          ♪ 自分の録音を確認する
        <% end %>
      </div>
    </div>

    <!-- 伴奏動画 -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">
      <h2 class="text-sm font-semibold text-green-900 tracking-wide mb-5 pb-3 border-b border-stone-100">
        伴奏動画
      </h2>

      <div class="text-center mb-5">
        <%= link_to videos_path,
            class: "inline-block px-6 py-2 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
          ♪ 伴奏動画を選択する
        <% end %>
      </div>

      <div class="flex justify-center">
        <% if @selected_video.present? %>
          <div class="text-center w-full">
            <iframe width="100%" height="280"
              src="https://www.youtube.com/embed/<%= find_youtube_id(@selected_video.video_url) %>"
              frameborder="0"
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="rounded-xl shadow-sm">
            </iframe>
            <div class="mt-4">
              <%= link_to video_path(@selected_video),
                  data: { turbo_method: :delete, turbo_confirm: "伴奏動画を削除しますか？" },
                  class: "px-5 py-2 bg-red-700/80 hover:bg-red-700 text-white text-sm font-semibold rounded-full shadow-sm transition duration-300" do %>
                削除
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="text-center py-10">
            <p class="text-stone-400 text-sm">伴奏動画が選択されていません</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- フッターナビ -->
    <div class="flex justify-center gap-3">
      <%= link_to root_path,
          class: "px-6 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 font-semibold rounded-full text-sm shadow-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
      <%= link_to mypage_path,
          class: "px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        マイページに戻る
      <% end %>
    </div>

  </div>
</div>