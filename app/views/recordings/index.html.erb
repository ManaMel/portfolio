<%= render 'layouts/header' %>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-5xl mx-auto px-4 py-8">
    
    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">♪ 歌声や演奏を録音 ♪</h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>

    <!-- 録音操作エリア -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        録音コントロール
      </h2>

      <!-- 録音ボタン -->
      <div class="flex justify-center gap-4 mb-6">
        <button type="button" id="buttonStart" 
                class="px-6 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300 disabled:bg-gray-400 disabled:text-gray-200">
          録音開始
        </button>
        <button type="button" id="buttonStop" 
                class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-300 disabled:bg-gray-400 disabled:text-gray-200" 
                disabled>
          録音停止
        </button>
        <button type="button" id="buttonPlay" 
                class="px-6 py-3 bg-pink-600 hover:bg-pink-700 text-white font-semibold rounded-lg shadow-md transition duration-300 disabled:bg-gray-400 disabled:text-gray-200">
          再生
        </button>
      </div>

      <!-- 波形表示 -->
      <div id="waveform" class="border-2 border-gray-200 rounded-lg p-2 bg-gray-50"></div>
    </div>

    <!-- エフェクト設定エリア -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        エフェクト設定
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-semibold text-green-800 mb-2">
            音量
          </label>
          <input type="range" id="volumeSlider" min="0" max="10" step="0.01" value="1" 
                 class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
        </div>

        <div>
          <label class="block text-sm font-semibold text-green-800 mb-2">
            リバーブ
          </label>
          <input type="range" id="reverbSlider" min="0" max="1" step="0.01" value="0.5" 
                 class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
        </div>

        <div>
          <label class="block text-sm font-semibold text-green-800 mb-2">
            エコー遅延時間
          </label>
          <input type="range" id="echoDelay" min="0" max="1" step="0.01" value="0.3" 
                 class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
        </div>

        <div>
          <label class="block text-sm font-semibold text-green-800 mb-2">
            エコー残響量
          </label>
          <input type="range" id="echoFeedback" min="0" max="0.95" step="0.01" value="0.4" 
                 class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
        </div>
      </div>
    </div>

    <!-- 録音保存エリア -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        録音を保存
      </h2>

      <div class="mb-4">
        <label class="block text-sm font-semibold text-green-800 mb-2">
          タイトル
        </label>
        <input id="recording_title" type="text" 
               placeholder="例：サビだけ録音 2025/01/01" 
               class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition">
      </div>

      <div class="mb-6 p-4 bg-gray-50 rounded-lg border-l-4 border-amber-500">
        <p class="text-sm font-semibold text-gray-700 mb-1">録音データ</p>
        <div id="recording-info" class="text-sm text-gray-600">
          ※ まだ録音データが未取得です
        </div>
      </div>

      <button id="save-recording-btn" 
              class="w-full py-3 bg-amber-500 hover:bg-amber-600 text-green-900 font-bold rounded-lg shadow-md transition duration-300 disabled:bg-gray-400 disabled:text-gray-200" 
              disabled>
        保存する
      </button>

      <div class="mt-4 text-center">
        <%= link_to mypage_path, 
            class: "inline-block px-6 py-2 border-2 border-amber-500 text-amber-600 hover:bg-amber-50 font-semibold rounded-lg transition duration-300" do %>
          ♪ 自分の録音を確認する
        <% end %>
      </div>
    </div>

    <!-- 伴奏動画エリア -->
    <div class="bg-white rounded-lg shadow-xl p-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        伴奏動画
      </h2>

      <div class="text-center mb-4">
        <%= link_to videos_path, 
            class: "inline-block px-6 py-2 border-2 border-amber-500 text-amber-600 hover:bg-amber-50 font-semibold rounded-lg transition duration-300" do %>
          ♪ 伴奏動画を選択する
        <% end %>
      </div>

      <div class="flex justify-center">
        <% if @selected_video.present? %>
          <div class="text-center">
            <iframe width="560" height="315"
              src="https://www.youtube.com/embed/<%= find_youtube_id(@selected_video.video_url) %>"
              frameborder="0"
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="rounded-lg shadow-lg">
            </iframe>

            <div class="mt-4">
              <%= link_to video_path(@selected_video), 
                  data: { turbo_method: :delete, turbo_confirm: "伴奏動画を削除しますか？" },
                  class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow-md transition duration-300" do %>
                削除
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="text-center py-12">
            <div class="text-6xl mb-4"></div>
            <p class="text-gray-600">伴奏動画が選択されていません</p>
          </div>
        <% end %>
      </div>
    </div>
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300 mr-4" do %>
        ♪ ホームへ戻る
      <% end %>
      <%= link_to mypage_path, 
          class: "inline-block px-8 py-3 border-2 border-amber-500 text-amber-600 hover:bg-amber-50 font-semibold rounded-lg transition duration-300" do %>
        マイページに戻る
      <% end %>
    </div>
  </div>
</div>