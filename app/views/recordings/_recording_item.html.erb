<div id="<%= dom_id(recording) %>" class="border border-gray-200 rounded-lg p-6 bg-white hover:border-green-800 hover:shadow-md transition duration-300 mb-4">
  
  <!-- タイトルと削除ボタン -->
  <div class="flex justify-between items-start mb-4 pb-3 border-b-2 border-amber-400">
    <h3 class="text-xl font-serif font-semibold text-green-800"><%= recording.title %></h3>
    
    <%= link_to recording_path(recording),
        data: { turbo_method: :delete, turbo_confirm: "録音をすべて削除しますか？" },
        class: "flex items-center text-red-600 hover:text-red-800 text-sm font-medium transition" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 6h6v10H7V6z" clip-rule="evenodd" />
      </svg>
      削除
    <% end %>
  </div>

  <!-- ステータス表示 -->
  <% status_class = case recording.status
    when 'completed' then 'bg-green-100 text-green-800 border-green-800'
    when 'failed' then 'bg-red-100 text-red-800 border-red-800'
    when 'mixing' then 'bg-amber-100 text-amber-800 border-amber-800 animate-pulse'
    else 'bg-gray-100 text-gray-600 border-gray-600'
  end %>

  <div class="mb-4">
    <span class="inline-block px-4 py-1.5 text-sm font-semibold rounded-full border-2 <%= status_class %>">
      <%= t("recording_statuses.#{recording.status}", default: recording.status.humanize) %>
    </span>
    <% if recording.status == 'failed' && recording.error_message.present? %>
      <p class="text-sm text-red-600 mt-2">エラー: <%= recording.error_message %></p>
    <% end %>
  </div>
  
  <!-- 元の録音 -->
  <div class="mb-4">
    <p class="font-semibold text-green-800 mb-2">元の録音</p>
    <div class="flex items-center gap-2">
      <% if recording.original_audio.attached? %>
        <audio controls class="flex-grow">
          <source src="<%= url_for(recording.original_audio) %>">
        </audio>
        <%= link_to destroy_original_recording_path(recording),
            data: { turbo_method: :delete, turbo_confirm: "元音声削除しますか？" },
            class: "text-red-500 hover:text-red-700 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 6h6v10H7V6z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-500">元音声なし</p>
      <% end %>
    </div>
  </div>

  <!-- 伴奏 -->
  <div class="mb-4">
    <p class="font-semibold text-green-800 mb-2">伴奏ファイル</p>
    <div class="flex items-center gap-2">
      <% if recording.accompaniment.attached? %>
        <audio controls class="flex-grow">
          <source src="<%= url_for(recording.accompaniment) %>">
        </audio>
        <%= link_to destroy_accompaniment_recording_path(recording),
            data: { turbo_method: :delete, turbo_confirm: "伴奏削除しますか？" },
            class: "text-red-500 hover:text-red-700 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 6h6v10H7V6z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% else %>
        <%= link_to "伴奏を選ぶ", select_accompaniment_recording_path(recording), 
            class: "px-4 py-2 bg-amber-500 hover:bg-amber-600 text-green-900 text-sm font-semibold rounded shadow-md transition" %>
      <% end %>
    </div>
  </div>

  <!-- ミックス済み音声 -->
  <div class="mb-4">
    <p class="font-semibold text-green-800 mb-2">ミックス済み音声</p>
    <div class="flex items-center gap-2">
      <% if recording.generated_audio.attached? %>
        <audio controls class="flex-grow">
          <source src="<%= url_for(recording.generated_audio) %>" type="<%= recording.generated_audio.content_type %>">
        </audio>
        <%= link_to destroy_generated_recording_path(recording),
            data: { turbo_method: :delete, turbo_confirm: "生成音削除しますか？" },
            class: "text-red-500 hover:text-red-700 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 6h6v10H7V6z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-500">まだ生成されていません</p>
      <% end %>
    </div>
  </div>
  
  <!-- 調整ページへのリンク -->
  <div class="mb-4 text-center">
    <%= link_to "ディレイ・ゲインを調整する", recording_path(recording), 
        class: "inline-block px-6 py-2 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" %>
  </div>

  <!-- 音声生成フォーム -->
  <div>
    <%= form_with url: generate_audio_recording_path(recording), method: :post, local: true, data: { turbo: true } do %>
      <% is_disabled = !recording.original_audio.attached? || !recording.accompaniment.attached? %>

      <% if recording.status == 'mixing' %>
        <%= submit_tag "生成中...", 
            class: "w-full py-2 bg-gray-400 text-gray-200 font-semibold rounded-lg", 
            disabled: true %>
      <% elsif recording.generated_audio.attached? %>
        <%= submit_tag "再生成する", 
            class: "w-full py-2 bg-amber-500 hover:bg-amber-600 text-green-900 font-semibold rounded-lg shadow-md transition duration-300 #{'opacity-50 cursor-not-allowed' if is_disabled}", 
            disabled: is_disabled %>
      <% else %>
        <%= submit_tag "音声を生成する", 
            class: "w-full py-2 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300 #{'opacity-50 cursor-not-allowed' if is_disabled}", 
            disabled: is_disabled %>
      <% end %>
      
      <% if is_disabled %>
        <p class="text-xs text-red-600 text-center mt-2">※ 元音声と伴奏の両方が必要です。</p>
      <% end %>
    <% end %>
  </div>
</div>