<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-2xl mx-auto px-5 py-10">

    <!-- ページタイトル -->
    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Upload</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        伴奏ファイルをアップロード
      </h2>
    </div>

    <!-- メインカード -->
    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-6 py-6 mb-6">

      <!-- 録音タイトル -->
      <h3 class="text-sm font-semibold text-green-900 mb-5 pb-3 border-b border-stone-100">
        <%= @recording.title %>
      </h3>

      <!-- インフォメーション -->
      <div class="bg-blue-50 border-l-2 border-blue-400 text-blue-800 p-3 rounded-xl mb-5">
        <p class="text-xs">この録音に伴奏ファイルをアップロードすると、タイミング調整ができるようになります。</p>
      </div>

      <!-- 録音情報 -->
      <div class="bg-stone-50 rounded-xl border border-stone-100 p-4 mb-5">
        <div class="space-y-2 text-xs text-stone-500">
          <div>
            <span class="font-semibold text-stone-600">録音ファイル: </span>
            <% if @recording.original_audio.attached? %>
              <span class="text-green-700 font-semibold">✓ あり</span>
              <span class="text-stone-400">(<%= number_to_human_size(@recording.original_audio.byte_size) %>)</span>
            <% else %>
              <span class="text-red-600">✗ なし</span>
            <% end %>
          </div>
          <div>
            <span class="font-semibold text-stone-600">伴奏ファイル: </span>
            <% if @recording.accompaniment.attached? %>
              <span class="text-green-700 font-semibold">✓ <%= @recording.accompaniment.filename %></span>
              <span class="text-stone-400">(<%= number_to_human_size(@recording.accompaniment.byte_size) %>)</span>
            <% else %>
              <span class="text-amber-600">⚠ 未設定</span>
            <% end %>
          </div>
        </div>
      </div>

      <!-- アップロードフォーム -->
      <%= form_with(
        model: @recording,
        url: update_accompaniment_recording_path(@recording),
        method: :patch,
        data: { turbo: false }
      ) do |f| %>

        <div class="mb-6">
          <%= f.label :accompaniment, "伴奏ファイルを選択", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <p class="text-xs text-stone-400 mb-2">対応形式: MP3, WAV, OGG, M4A など</p>
          <%= f.file_field :accompaniment,
              accept: "audio/*",
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-600 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              required: true %>
        </div>

        <div class="flex justify-between items-center">
          <%= link_to "キャンセル", mypage_path,
              class: "text-sm text-stone-400 hover:text-stone-600 underline underline-offset-2 transition" %>
          <%= f.submit @recording.accompaniment.attached? ? "伴奏を変更" : "伴奏をアップロード",
              class: "px-7 py-2.5 bg-green-900 hover:bg-green-800 text-amber-100 text-sm font-bold rounded-full shadow-sm tracking-wide transition duration-300 cursor-pointer",
              data: { disable_with: "アップロード中..." } %>
        </div>

      <% end %>
    </div>

    <!-- ホームへ戻る -->
    <div class="text-center">
      <%= link_to root_path,
          class: "inline-block px-6 py-2.5 border border-green-800/40 hover:bg-green-900 text-green-900 hover:text-amber-100 font-semibold rounded-full text-sm transition duration-300" do %>
        ホームへ戻る
      <% end %>
    </div>

  </div>
</div>