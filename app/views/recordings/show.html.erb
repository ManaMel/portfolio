<%= render 'layouts/header' %>

<% 
  original_audio_url = @recording.original_audio.attached? ? url_for(@recording.original_audio) : nil
  accomp_audio_url = @recording.accompaniment.attached? ? url_for(@recording.accompaniment) : nil
  initial_delay_seconds = @recording.recording_delay.presence || 0.0
  initial_vocal_gain = @recording.vocal_gain.presence || 0.5
%>

<div class="min-h-screen bg-gray-100">
  <div class="max-w-3xl mx-auto px-4 py-8">

    <!-- タイトル -->
    <div class="text-center mb-8">
      <h1 class="text-4xl font-serif font-bold text-green-800 mb-2">
        <%= @recording.title %>
      </h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto"></div>
    </div>

    <!-- エラー：音声ファイルが見つからない場合 -->
    <% if original_audio_url.nil? || accomp_audio_url.nil? %>
      <div class="bg-red-100 border-l-4 border-red-800 text-red-800 p-4 rounded mb-6">
        <p>必要な音声ファイルが見つかりません。オリジナル録音または伴奏ファイルを確認してください。</p>
      </div>
      <%= link_to mypage_path, 
          class: "inline-block px-6 py-3 bg-amber-500 hover:bg-amber-600 text-green-900 font-semibold rounded-lg shadow-md transition duration-300" do %>
        マイページに戻る
      <% end %>
      <% return %>
    <% end %>

    <!-- ステータス表示 -->
    <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
      <h2 class="text-xl font-serif font-semibold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
        ステータス
      </h2>
      <div class="flex items-center gap-3">
        <span class="text-lg text-gray-700">現在の状態:</span>
        <span class="px-4 py-1.5 rounded-full text-sm font-semibold <%= 
          case @recording.status.to_sym
          when :created then 'bg-blue-100 text-blue-800'
          when :generating then 'bg-amber-100 text-amber-800'
          when :generated then 'bg-green-100 text-green-800'
          when :failed then 'bg-red-100 text-red-800'
          end
        %>">
          <%= 
            case @recording.status.to_sym
            when :created then '作成済み'
            when :generating then '処理中'
            when :generated then '完了'
            when :failed then '失敗'
            end
          %>
        </span>
      </div>

      <% if @recording.generating? %>
        <div class="bg-blue-50 border-l-4 border-blue-800 text-blue-800 p-4 rounded mt-4">
          <div class="flex items-center gap-2">
            <span class="animate-spin inline-block w-5 h-5 border-2 border-blue-800 border-t-transparent rounded-full"></span>
            <span>ミキシング処理中です。完了までしばらくお待ちください...</span>
          </div>
        </div>
        <script>
          setTimeout(() => location.reload(), 5000);
        </script>
      <% elsif @recording.failed? %>
        <div class="bg-red-50 border-l-4 border-red-800 text-red-800 p-4 rounded mt-4">
          <p class="font-semibold">ミキシング処理に失敗しました</p>
          <% if @recording.error_message.present? %>
            <p class="text-sm mt-2"><%= @recording.error_message %></p>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- ミキシング完了時：結果の再生 -->
    <% if @recording.generated? && @recording.generated_audio.attached? %>
      <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
        <h2 class="text-2xl font-serif font-bold text-green-800 mb-4 pb-3 border-b-2 border-amber-400">
          ミキシング完了！
        </h2>
        <p class="text-gray-700 mb-6">録音と伴奏がミキシングされました。</p>
        
        <div class="bg-gray-50 p-6 rounded-lg border-l-4 border-green-800">
          <h3 class="font-semibold text-green-800 mb-3">ミキシング結果</h3>
          <audio controls class="w-full mb-4" preload="metadata">
            <source src="<%= url_for(@recording.generated_audio) %>" type="audio/mpeg">
            お使いのブラウザは音声再生に対応していません。
          </audio>
          
          <div class="text-right">
            <%= link_to "ダウンロード", 
                rails_blob_path(@recording.generated_audio, disposition: "attachment"), 
                class: "inline-block px-6 py-2 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300" %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- 調整とプレビュー -->
    <% unless @recording.generated_audio.attached? %>
      <div 
        data-timing-adjuster
        data-original-url="<%= original_audio_url %>"
        data-accomp-url="<%= accomp_audio_url %>"
        data-initial-delay="<%= initial_delay_seconds %>"
        data-initial-gain="<%= initial_vocal_gain %>"
      ></div>
      
      <div class="bg-white rounded-lg shadow-xl p-6 mb-6 border-t-4 border-green-800">
        <h2 class="text-2xl font-serif font-bold text-green-800 mb-6 pb-3 border-b-2 border-amber-400">
          調整とプレビュー
        </h2>
        
        <!-- プレビュー再生ボタン -->
        <div class="mb-8">
          <button type="button" id="playPreviewButton" 
                  class="w-full py-3 px-4 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300 disabled:bg-gray-400 disabled:text-gray-200" 
                  disabled>
            <span id="playButtonText">音声ファイルを読み込み中...</span>
          </button>
        </div>

        <!-- 調整値保存フォーム -->
        <%= form_with(model: @recording, url: mix_recording_path(@recording), method: :post, local: true, html: { id: "timingAdjustmentForm" }) do |f| %>

          <%= f.hidden_field :recording_delay, value: initial_delay_seconds, id: 'hidden_delay_field' %>
          <%= f.hidden_field :vocal_gain, value: initial_vocal_gain, id: 'hidden_gain_field' %>

          <!-- ディレイ調整 -->
          <div class="mb-6">
            <label for="delay-slider" class="block text-sm font-semibold text-green-800 mb-2">
              ディレイ (時間調整): <span id="delay-value" class="text-amber-600">
                <%= '%.2f' % initial_delay_seconds %>
              </span> 秒
            </label>
            
            <input type="range" 
                  id="delay-slider"
                  min="-5" 
                  max="5" 
                  step="0.05" 
                  value="<%= initial_delay_seconds %>" 
                  class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
            <div class="flex justify-between text-xs text-gray-500 mt-1">
              <span>-5秒 (早く開始)</span>
              <span>+5秒 (遅く開始)</span>
            </div>
          </div>

          <!-- ボーカル音量調整 -->
          <div class="mb-8">
            <label for="gain-slider" class="block text-sm font-semibold text-green-800 mb-2">
              ボーカル音量比率: <span id="gain-value" class="text-amber-600">
                <%= '%.2f' % initial_vocal_gain %>
              </span>
            </label>
            
            <input type="range" 
                  id="gain-slider"
                  min="0.0" 
                  max="1.0" 
                  step="0.01" 
                  value="<%= initial_vocal_gain %>" 
                  class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
            <div class="flex justify-between text-xs text-gray-500 mt-1">
              <span>0.0 (無音)</span>
              <span>1.0 (最大)</span>
            </div>
            <p class="text-xs text-gray-500 mt-2">※ 伴奏の音量は自動的に (1 - この値) で調整されます</p>
          </div>

          <!-- ミキシング実行ボタン -->
          <%= f.submit '調整値を保存してミキシング開始', 
                      class: "w-full py-3 px-4 bg-amber-500 hover:bg-amber-600 text-green-900 font-bold rounded-lg shadow-md transition duration-300", 
                      data: { disable_with: "ミキシング処理中..." },
                      id: "submit-mix-button" %>
          
          <!-- デバッグ情報 -->
          <div class="text-xs text-gray-500 p-3 bg-gray-50 rounded mt-4">
            <p class="font-semibold mb-1">現在の調整値:</p>
            <p>Delay: <span id="current-delay-debug"><%= initial_delay_seconds %></span>秒</p>
            <p>Gain: <span id="current-gain-debug"><%= initial_vocal_gain %></span></p>
          </div>

        <% end %>
      </div>
    <% end %>
    
    <!-- ホームへ戻る -->
    <div class="text-center py-8">
      <%= link_to root_path, 
          class: "inline-block px-8 py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-semibold rounded-lg shadow-md transition duration-300 mr-4" do %>
        ♪ ホームへ戻る
      <% end %>
      <%= link_to mypage_path, 
          class: "inline-block px-8 py-3 border-2 border-amber-500 text-amber-600 hover:bg-amber-50 font-semibold rounded-lg transition duration-300" do %>
        マイページに戻る
      <% end %>
    </div>
  </div>
</div>