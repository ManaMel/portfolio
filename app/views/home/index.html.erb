<%= render 'layouts/header' %>

<div class="min-h-screen bg-stone-50">
  <div class="max-w-md mx-auto px-5 py-10">

    <div class="text-center mb-8">
      <p class="text-green-800/60 text-xs font-medium tracking-widest uppercase mb-2">Main Menu</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        メニュー
      </h2>
    </div>

    <div class="space-y-3">
      <%= link_to recordings_path,
          class: "group flex items-center justify-between w-full px-6 py-4 bg-white hover:bg-green-900 border border-stone-200 hover:border-green-900 rounded-xl shadow-sm hover:shadow-md transition-all duration-300" do %>
        <div class="flex items-center gap-3">
          <span class="text-green-700 group-hover:text-amber-200 text-lg transition-colors duration-300">♪</span>
          <span class="text-green-900 group-hover:text-amber-100 font-semibold">録音する</span>
        </div>
        <span class="text-stone-300 group-hover:text-amber-200/70 transition-colors duration-300">›</span>
      <% end %>

      <%= link_to videos_path,
          class: "group flex items-center justify-between w-full px-6 py-4 bg-white hover:bg-green-900 border border-stone-200 hover:border-green-900 rounded-xl shadow-sm hover:shadow-md transition-all duration-300" do %>
        <div class="flex items-center gap-3">
          <span class="text-green-700 group-hover:text-amber-200 text-lg transition-colors duration-300">♪</span>
          <span class="text-green-900 group-hover:text-amber-100 font-semibold">伴奏再生する</span>
        </div>
        <span class="text-stone-300 group-hover:text-amber-200/70 transition-colors duration-300">›</span>
      <% end %>

      <%= link_to video_generations_path,
          class: "group flex items-center justify-between w-full px-6 py-4 bg-white hover:bg-green-900 border border-stone-200 hover:border-green-900 rounded-xl shadow-sm hover:shadow-md transition-all duration-300" do %>
        <div class="flex items-center gap-3">
          <span class="text-green-700 group-hover:text-amber-200 text-lg transition-colors duration-300">♪</span>
          <span class="text-green-900 group-hover:text-amber-100 font-semibold">動画作成する</span>
        </div>
        <span class="text-stone-300 group-hover:text-amber-200/70 transition-colors duration-300">›</span>
      <% end %>

      <%= link_to guidelines_path,
          class: "group flex items-center justify-between w-full px-6 py-4 bg-white hover:bg-green-900 border border-stone-200 hover:border-green-900 rounded-xl shadow-sm hover:shadow-md transition-all duration-300" do %>
        <div class="flex items-center gap-3">
          <span class="text-green-700 group-hover:text-amber-200 text-lg transition-colors duration-300">♪</span>
          <span class="text-green-900 group-hover:text-amber-100 font-semibold">投稿ガイドライン</span>
        </div>
        <span class="text-stone-300 group-hover:text-amber-200/70 transition-colors duration-300">›</span>
      <% end %>

      <%= link_to mypage_path,
          class: "flex items-center justify-between w-full px-6 py-4 bg-green-900 hover:bg-green-800 rounded-xl shadow-md hover:shadow-lg transition-all duration-300 mt-6" do %>
        <div class="flex items-center gap-3">
          <span class="text-amber-200 text-lg">♪</span>
          <span class="text-amber-100 font-bold">マイページ</span>
        </div>
        <span class="text-amber-200/70">›</span>
      <% end %>
    </div>

  </div>
</div>