<%= render 'layouts/header' %>

<div class="container mx-auto px-4 py-8 max-w-md">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl justify-center mb-6">新しいパスワードを設定</h2>

      <%= form_for(url: password_path html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <!-- 新しいパスワード -->
        <div class="form-control mb-4">
          <%= f.label :password, "新しいパスワード", class: "label" %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "input input-bordered w-full", placeholder: "8文字以上" %>
          <% if @minimum_password_length %>
            <label class="label">
              <span class="label-text-alt text-gray-500">最低 <%= @minimum_password_length %> 文字</span>
            </label>
          <% end %>
        </div>

        <!-- パスワード確認 -->
        <div class="form-control mb-4">
          <%= f.label :password_confirmation, "パスワード確認", class: "label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full", placeholder: "もう一度入力" %>
        </div>

        <!-- 送信ボタン -->
        <div class="form-control mt-6">
          <%= f.submit "パスワードを変更", class: "btn btn-primary btn-block" %>
        </div>
      <% end %>

      <!-- その他のリンク -->
      <div class="divider">または</div>
      
      <div class="text-center">
        <%= link_to "ログイン", new_session_path, class: "link link-primary" %>
      </div>
    </div>
  </div>
</div>