<header class="bg-green-900 border-b border-amber-200/40 py-3 px-5 flex items-center shadow-lg">
  <div class="flex items-center gap-2">
    <span class="text-amber-200 text-2xl">♪</span>
    <h1 class="text-2xl font-bold text-amber-200 tracking-widest font-serif">Mysic</h1>
  </div>
</header>

<div class="min-h-screen bg-stone-50 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <p class="text-green-800/50 text-xs font-medium tracking-widest uppercase mb-2">Sign In</p>
      <h2 class="text-2xl font-serif font-bold text-green-900 border-b border-amber-300/60 pb-3 inline-block px-6">
        ログイン
      </h2>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-stone-200 px-8 py-8">
      <%= form_with model: @user, url: user_session_path, local: true, class: "space-y-5" do |f| %>
        <div>
          <%= f.label :email, "メールアドレス", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= f.email_field :email,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              placeholder: "例: user@example.com" %>
        </div>

        <div>
          <%= f.label :password, "パスワード", class: "block text-xs font-semibold text-green-900 tracking-wide mb-1.5" %>
          <%= f.password_field :password,
              class: "w-full px-4 py-3 border border-stone-200 rounded-xl text-sm text-stone-800 placeholder-stone-300 focus:border-green-700 focus:outline-none focus:ring-1 focus:ring-green-700/30 transition",
              placeholder: "パスワードを入力" %>
        </div>

        <div class="text-right -mt-2">
          <%= link_to "パスワードを忘れた方", new_user_password_path,
              class: "text-xs text-stone-400 hover:text-green-700 transition" %>
        </div>

        <%= f.submit "ログイン",
            class: "w-full py-3 bg-green-900 hover:bg-green-800 text-amber-100 font-bold rounded-full shadow-md tracking-wide text-sm transition duration-300 cursor-pointer" %>
      <% end %>
    </div>

    <div class="text-center mt-5">
      <p class="text-stone-500 text-sm">
        アカウントをお持ちでない方は
        <%= link_to "新規会員登録", new_user_registration_path,
            class: "font-semibold text-green-800 hover:text-green-600 underline underline-offset-2 transition" %>
      </p>
    </div>

  </div>
</div>