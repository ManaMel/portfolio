<div class="bg-green-800 border-b-4 border-amber-500 py-4 px-6 flex justify-between items-center shadow-md">
    <h1 class="text-3xl font-serif font-bold text-amber-400">MYSIC</h1>
</div>
<div class="min-h-screen bg-gray-100 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <!-- ログインカード -->
    <div class="bg-white rounded-lg shadow-xl p-8 border-t-4 border-green-800">
      <h1 class="text-3xl font-serif font-bold text-green-800 text-center mb-2">
        ログイン
      </h1>
      <div class="w-16 h-1 bg-amber-400 mx-auto mb-8"></div>

      <%= form_with model: @user, url: user_session_path, local: true, class: "space-y-4" do |f| %>
        <div>
          <%= f.label :email, "メールアドレス", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.email_field :email, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition",
              placeholder: "例: user@example.com" %>
        </div>

        <div>
          <%= f.label :password, "パスワード", class: "block text-sm font-semibold text-green-800 mb-2" %>
          <%= f.password_field :password, 
              class: "w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-green-800 focus:outline-none transition",
              placeholder: "パスワードを入力" %>
        </div>

        <%= f.submit "ログイン", 
            class: "w-full py-3 bg-green-800 hover:bg-green-700 text-amber-300 font-bold rounded-lg shadow-md transition duration-300 cursor-pointer" %>
      <% end %>

      <div class="text-center mt-6">
        <%= link_to "パスワードを忘れた方", new_user_password_path, 
            class: "text-sm text-green-700 hover:text-green-900 hover:underline" %>
      </div>
    </div>

    <!-- 新規登録へのリンク -->
    <div class="bg-white rounded-lg shadow-md p-4 mt-4 text-center border-l-4 border-amber-500">
      <p class="text-gray-700">
        アカウントをお持ちでない方は
        <%= link_to "新規登録", new_user_registration_path, 
            class: "font-semibold text-amber-600 hover:text-amber-700 hover:underline" %>
      </p>
    </div>
  </div>
</div>